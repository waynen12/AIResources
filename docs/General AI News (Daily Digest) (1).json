      "parameters": {
        "jsCode": "const items = $input.all();\nconst summary = items.map(item => \n  `Title: ${item.json.title}\\nLink: ${item.json.link}\\nDescription: ${item.json.contentSnippet || item.json.description || ''}\\n---`\n).join('\\n');\n\nreturn [{ json: { all_items: summary } }];\n"
      },
