    {
      "parameters": {
        "jsCode": "// Grab the digest HTML from the earlier Code node\n// Change 'Strip Code Fences' to whatever your Code node is actually named\nconst html = $('Strip Code Fences').first().json.html;\n\n// Strip HTML tags to get plain text\nconst plainText = html\n  .replace(/<h1[^>]*>(.*?)<\\/h1>/gi, '$1\\n\\n')\n  .replace(/<h2[^>]*>(.*?)<\\/h2>/gi, '\\n$1:\\n')\n  .replace(/<a[^>]*href=\"([^\"]*)\"[^>]*>(.*?)<\\/a>/gi, '$2')\n  .replace(/<p[^>]*>(.*?)<\\/p>/gi, '$1\\n')\n  .replace(/<[^>]+>/g, '')\n  .replace(/\\n{3,}/g, '\\n\\n')\n  .trim();\n\nreturn [{ json: { plainText, html } }];\n"
      },
