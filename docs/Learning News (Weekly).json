        "responses": {
          "values": [
            {
              "content": "=You are a personal AI learning advisor. From the articles below, identify topics and tools that a developer focused on AI fluency should learn about.\n\nYour reader's interests: VS Code, Visual Studio, claude code, codex, RAG, AI APIs, AI in game development, new developer tools, automation, and emerging AI techniques.\n\nCreate a weekly learning digest suitable for a telegram message:.\n\nRules:\n- Try to style the text in a nice format for a telegram message\n- Use ONLY inline styles on every element. No <style> blocks.\n- Colors: headers #1a2942, links #3b82f6, body text #333333, accent #06b6d4.\n\nFormat:\n- Open with \"This Week's Learning Radar\" header\n- Group into: \"New Tools & Features\", \"Skills to Explore\", \"Worth Watching\"\n- For each item: title as a clickable link, 1 sentence on what it is, and 1 sentence on WHY it's worth learning\n- End with a \"Quick Wins\" section: 2-3 things the reader could try in 15 minutes\n- Skip anything not relevant to the reader's interests listed above\n\nArticles:\n{{ $json.all_items }}\n"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
