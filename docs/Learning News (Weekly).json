      "parameters": {
        "jsCode": "const script = $('Generate Video Script').first().json.output[0].content[0].text;\nconst metadataRaw = $('Generate Video Metadata').first().json.output[0].content[0].text;\n\nlet metadata;\ntry {\n  const cleaned = metadataRaw.replace(/^```json?\\n?/, '').replace(/\\n?```$/, '');\n  metadata = JSON.parse(cleaned);\n} catch (e) {\n  metadata = {\n    title: \"Weekly AI & Dev Tools Roundup\",\n    description: \"This week's highlights in AI and developer tools.\",\n    tags: [\"AI\", \"developer tools\", \"weekly roundup\"]\n  };\n}\n\nreturn [{\n  json: {\n    script,\n    title: metadata.title,\n    description: metadata.description,\n    tags: metadata.tags || [],\n    date: new Date().toISOString().split('T')[0],\n    didRequestBody: JSON.stringify({\n      source_url: \"https://clips-presenters.d-id.com/v2/kayla/xQFytx9Fdn/pHEObaJ86G/image.png\",\n      script: {\n        type: \"text\",\n        input: script,\n        provider: {\n          type: \"microsoft\",\n          voice_id: \"en-US-JennyNeural\"\n        }\n      },\n      config: {\n        result_format: \"mp4\",\n        \"stitch\": true\n      }\n    })\n  }\n}];"
