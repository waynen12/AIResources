        "jsCode": "const text = $input.first().json.output[0].content[0].text;\n\n// Strip markdown code fences\nconst cleanHtml = text\n  .replace(/^```html\\n?/, '')\n  .replace(/\\n?```$/, '');\n\nreturn [{ json: { html: cleanHtml } }];\n"
