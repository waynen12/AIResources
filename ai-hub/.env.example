# Copy this file to .env.local and customise for your deployment
NEXT_PUBLIC_SITE_NAME="AI Hub"

# Required for Auth.js v5 JWT signing
# Generate with: openssl rand -hex 32
AUTH_SECRET=""

# Canonical URL for Auth.js (required in production)
AUTH_URL="https://hub.notrauto.org"

# Required for AI provider API key encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETTINGS_ENCRYPTION_KEY=""
